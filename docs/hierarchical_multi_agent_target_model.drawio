        <mxCell id="term_agent" value="&lt;b&gt;Echter Agent&lt;/b&gt;&lt;br&gt;Runtime-Akteur mit Mandat, eigenem Arbeitsloop und supervisor-gebundener Submission&lt;br&gt;Beispiele: company_intelligence, market_network, evidence_qa, critics, repair_agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;spacing=8;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="70" y="960" width="390" height="100" as="geometry" />
        </mxCell>
        <mxCell id="term_supervisor" value="&lt;b&gt;Supervisor&lt;/b&gt;&lt;br&gt;Koordiniert, plant, validiert, erlaubt A2A-Paare und promoted,&lt;br&gt;ist aber selbst kein fachlicher Research-Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=12;spacing=8;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="490" y="960" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="term_service" value="&lt;b&gt;Deterministischer Service&lt;/b&gt;&lt;br&gt;Nicht-agentische Governance- oder Infrastrukturkomponente&lt;br&gt;Beispiele: validator, entity_registry, artifact_store" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=12;spacing=8;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="880" y="960" width="390" height="100" as="geometry" />
        </mxCell>
        <mxCell id="term_output" value="&lt;b&gt;Liquisto Output&lt;/b&gt;&lt;br&gt;Strukturierte Agentenartefakte fuer Verhandlungsvorbereitung,&lt;br&gt;nicht starre Workflow-Step-Dateien" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=12;spacing=8;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="1300" y="960" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="hard_rules" value="&lt;b&gt;Harte Regeln&lt;/b&gt;&lt;br&gt;1. Keine freie Agent-zu-Agent-Kommunikation&lt;br&gt;2. Direkte A2A nur in erlaubten Rollenpaaren mit Schema und Turn-Limit&lt;br&gt;3. Nur validierte Ergebnisse werden promoted&lt;br&gt;4. Synthese fuehrt keine neuen unbelegten Fakten ein&lt;br&gt;5. Liquisto-Logik lebt in Agentenmandaten, nicht in einem linearen Workflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=12;spacing=8;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="70" y="1090" width="760" height="110" as="geometry" />
        </mxCell>
        <mxCell id="run_flow" value="&lt;b&gt;Laufbild&lt;/b&gt;&lt;br&gt;Input - case concierge - supervisor dispatch - parallel: company_intelligence / market_network / strategic_signals - critic / repair loops - evidence_qa - synthesis - exports" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4f46e5;fontSize=12;spacing=8;fontColor=#312e81;" vertex="1" parent="1">
          <mxGeometry x="860" y="1090" width="820" height="95" as="geometry" />
        </mxCell>

