        <mxCell id="svc_validator" value="&lt;b&gt;Validator Suite&lt;/b&gt;&lt;br&gt;Contract-, Evidence- und Crossref-Validation&lt;br&gt;&lt;i&gt;Kein Agent&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=12;spacing=8;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="1290" y="445" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="svc_registry" value="&lt;b&gt;Entity Registry&lt;/b&gt;&lt;br&gt;Kanonische Entities, Relations, Findings, Sources,&lt;br&gt;Provenance, Konflikte, IDs&lt;br&gt;&lt;i&gt;Kein Agent&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=12;spacing=8;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="1290" y="555" width="420" height="100" as="geometry" />
        </mxCell>
        <mxCell id="svc_artifacts" value="&lt;b&gt;Artifact Store&lt;/b&gt;&lt;br&gt;Mandate, Episodes, Submissions, Logs, Registry-Snapshots,&lt;br&gt;Run Status und Meta-Artefakte" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=12;spacing=8;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="1290" y="670" width="420" height="80" as="geometry" />
        </mxCell>
