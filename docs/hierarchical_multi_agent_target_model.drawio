        <mxCell id="runtime_note" value="&lt;b&gt;Aktueller Repo-Kern&lt;/b&gt;&lt;br&gt;Das Repository ist jetzt ein supervisor-gesteuertes Multi-Agent-System.&lt;br&gt;Die Liquisto-Anforderungen leben in Fachmandaten, Repair-Loops und strukturierten Exporten,&lt;br&gt;nicht in einem starren linearen Step-Workflow." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=12;spacing=8;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="410" height="120" as="geometry" />
        </mxCell>

        <mxCell id="user_ui" value="&lt;b&gt;User / UI&lt;/b&gt;&lt;br&gt;Input: Firmenname, Domain, optionale Produktkategorien&lt;br&gt;Run starten, Status verfolgen, Report lesen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;spacing=8;fontColor=#0c4a6e;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="concierge" value="&lt;b&gt;Case Concierge Agent&lt;/b&gt;&lt;br&gt;Nimmt das Mandat an und normalisiert das Intake in einen kanonischen Research Brief&lt;br&gt;Klaert Ziel, Liquisto-Kontext, Produktkategorien und offene Fragen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;spacing=8;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="330" y="330" width="230" height="120" as="geometry" />
        </mxCell>
        <mxCell id="supervisor" value="&lt;b&gt;Supervisor Runtime&lt;/b&gt;&lt;br&gt;Zentrale Koordination fuer Mandate, Phasen, Retries, Repair-Loops und Gates&lt;br&gt;Definiert erlaubte direkte A2A-Paare und promoted nur validierte Ergebnisse in den kanonischen Zustand" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=13;spacing=8;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="610" y="305" width="350" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rule_note" value="&lt;b&gt;Kommunikationsregel&lt;/b&gt;&lt;br&gt;Keine freie Agent-zu-Agent-Kommunikation&lt;br&gt;Direkte A2A nur in supervisor-definierten Rollenpaaren mit Schema, Turn-Limit und klarer Zustaendigkeit&lt;br&gt;Beispiele: Producer&lt;-&gt;Critic, Producer&lt;-&gt;Repair-Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontSize=12;spacing=8;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="990" y="320" width="230" height="140" as="geometry" />
        </mxCell>
        <mxCell id="critics" value="&lt;b&gt;Stage Critics&lt;/b&gt;&lt;br&gt;Fachliche Review-Instanzen fuer Coverage, Evidenz und Passung&lt;br&gt;&lt;i&gt;Erlaubtes Paar:&lt;/i&gt; Producer&lt;-&gt;Critic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;spacing=8;fontColor=#713f12;" vertex="1" parent="1">
          <mxGeometry x="620" y="500" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="repair" value="&lt;b&gt;Repair / Code Agent&lt;/b&gt;&lt;br&gt;Formuliert gezielte Nachbesserungen, Subtasks und Rewrites&lt;br&gt;&lt;i&gt;Erlaubtes Paar:&lt;/i&gt; Producer&lt;-&gt;Repair-Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;spacing=8;fontColor=#713f12;" vertex="1" parent="1">
          <mxGeometry x="805" y="500" width="185" height="70" as="geometry" />
        </mxCell>

        <mxCell id="company" value="&lt;b&gt;Company Intelligence Agent&lt;/b&gt;&lt;br&gt;Intake Company Profil&lt;br&gt;Wirtschaftslage und Bestandsdruck&lt;br&gt;&lt;br&gt;&lt;i&gt;Output:&lt;/i&gt; intake_company_profile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfccb;strokeColor=#65a30d;fontSize=12;spacing=8;fontColor=#365314;" vertex="1" parent="1">
          <mxGeometry x="90" y="565" width="240" height="155" as="geometry" />
        </mxCell>
        <mxCell id="market" value="&lt;b&gt;Market Network Agent&lt;/b&gt;&lt;br&gt;Peer-, Ersatzteil- und Cross-Industry-Abnehmer&lt;br&gt;Marktrelevanz und Kontaktansatz&lt;br&gt;&lt;br&gt;&lt;i&gt;Outputs:&lt;/i&gt; peer_buyers, spare_part_buyers, cross_industry_buyers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfccb;strokeColor=#65a30d;fontSize=12;spacing=8;fontColor=#365314;" vertex="1" parent="1">
          <mxGeometry x="360" y="565" width="255" height="155" as="geometry" />
        </mxCell>
        <mxCell id="signals" value="&lt;b&gt;Strategic Signals Agent&lt;/b&gt;&lt;br&gt;Branchenanalyse, Trendrichtung, Ueberkapazitaet, Nachfrageausblick&lt;br&gt;&lt;br&gt;&lt;i&gt;Output:&lt;/i&gt; industry_analysis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfccb;strokeColor=#65a30d;fontSize=12;spacing=8;fontColor=#365314;" vertex="1" parent="1">
          <mxGeometry x="645" y="565" width="250" height="155" as="geometry" />
        </mxCell>
        <mxCell id="evidence" value="&lt;b&gt;Evidence QA Agent&lt;/b&gt;&lt;br&gt;Prueft Evidenzqualitaet, n/v-Dichte und offene Luecken&lt;br&gt;&lt;br&gt;&lt;i&gt;Output:&lt;/i&gt; quality_review + Repair Backlog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfccb;strokeColor=#65a30d;fontSize=12;spacing=8;fontColor=#365314;" vertex="1" parent="1">
          <mxGeometry x="925" y="565" width="230" height="155" as="geometry" />
        </mxCell>
        <mxCell id="synthesis" value="&lt;b&gt;Synthesis Agent&lt;/b&gt;&lt;br&gt;Fuehrt validierte Artefakte ohne neue Fakten zusammen&lt;br&gt;&lt;br&gt;&lt;i&gt;Output:&lt;/i&gt; negotiation_brief + report sections" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=12;spacing=8;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="500" y="780" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="svc_brief" value="&lt;b&gt;Research Brief / Run Memory&lt;/b&gt;&lt;br&gt;company_name, web_domain, product_categories,&lt;br&gt;objective, language, constraints, notes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=12;spacing=8;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="1290" y="160" width="420" height="80" as="geometry" />
        </mxCell>
