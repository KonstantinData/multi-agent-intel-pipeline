        <mxCell id="subtitle" value="Supervisor-gesteuerte Orchestrierung, wenige echte Fachagenten, kontrollierte A2A-Schleifen in definierten Rollenpaaren, Liquisto-spezifische Outputs statt Workflow-Steps" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#4b5563;" vertex="1" parent="1">
