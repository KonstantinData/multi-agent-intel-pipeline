        <mxCell id="title" value="Hierarchisches Multi-Agent-Zielmodell fuer Liquisto Market Intel" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1f2937;" vertex="1" parent="1">
